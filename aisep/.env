# VITE_API_URL is intentionally left unset during local development.
# The Vite dev server proxy (vite.config.js) forwards /api/* to the backend,
# which avoids CORS. Set this variable only in your production environment.
# VITE_API_URL=https://api.aisep.tech
# VITE_API_URL=https://api.aisep.tech

VITE_ENV=development
